{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceRoundAI",
  "version": "0.2.0",
  "identifier": "com.voiceround.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --mode tauri",
    "beforeBuildCommand": "npm run build:tauri",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceRoundAI",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; media-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost https://api.openai.com https://api.github.com"
    }
  },
  "plugins": {
    "shell": {
      "open": "^https://github\\.com/rajat-mehra05/voice-round/releases(/.*)?$"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "./Info.plist"
    }
  }
}
